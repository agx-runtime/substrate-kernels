# Kernel source pin — the root of every reproducibility claim (ADR 0001).
#
# A bump is an explicit, reviewed change: update VERSION + SHA256 together, then
# re-validate the patch series (applies-clean), re-run olddefconfig + the
# config-invariant gate, and re-run boot-smoke. The tarball is fetched from
# kernel.org at this tag and verified against SHA256 BEFORE extraction; a mismatch
# fails the build (the source is never trusted on the version string alone).
#
# Line: the 6.12 LTS line (ADR 0001). The patch series is authored against this
# exact point release, so it applies at -p1 with zero fuzz.

KERNEL_VERSION=6.12.91
KERNEL_SHA256=0ff2ab9e169f9f1948557471fbb450d3018f8c5b77caf288e1a3982582597969
KERNEL_URL=https://cdn.kernel.org/pub/linux/kernel/v6.x/linux-6.12.91.tar.xz
