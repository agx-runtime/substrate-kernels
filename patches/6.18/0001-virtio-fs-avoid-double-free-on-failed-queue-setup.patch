From 95f50bc8708d05583a1b359ca51b6e199372fb15 Mon Sep 17 00:00:00 2001
From: Yung-Tse Cheng <mes900903@gmail.com>
Date: Mon, 20 Jul 2026 18:24:26 -0700
Subject: [PATCH 1/3] virtio-fs: avoid double-free on failed queue setup

Backport upstream commit 6af3330ec5d5fb8c06c04eb520a71cf73ea5a765. virtio_find_vqs() failure otherwise leaves two freed pointers for the final kobject release to free again. Substrate exposes virtio-fs, so a malformed queue count can reach this probe-failure path.
---
 fs/fuse/virtio_fs.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/fs/fuse/virtio_fs.c b/fs/fuse/virtio_fs.c
index b2f6486fe..2b3daa93e 100644
--- a/fs/fuse/virtio_fs.c
+++ b/fs/fuse/virtio_fs.c
@@ -988,7 +988,9 @@ static int virtio_fs_setup_vqs(struct virtio_device *vdev,
 	kfree(vqs);
 	if (ret) {
 		kfree(fs->vqs);
+		fs->vqs = NULL;
 		kfree(fs->mq_map);
+		fs->mq_map = NULL;
 	}
 	return ret;
 }
