From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: substrate <substrate-kernels@agx.so>
Date: Mon, 01 Jun 2026 00:00:00 +0000
Subject: [PATCH] kbuild: skip pahole -j when KBUILD_BUILD_TIMESTAMP is set

The `-j` (multithreading) flag was added to pahole's BTF generation in
v1.22 and is enabled unconditionally by scripts/Makefile.btf for pahole
v1.22+. Parallel BTF generation produces non-deterministic type_id
allocation, and those IDs are written into the `.BTF` and `.BTF_ids`
ELF sections of vmlinux. The result is that two identical builds of a
debug-info kernel produce different bytes in the BTF region, defeating
reproducibility (the substrate-kernels `repro-check` gate, CLAUDE.md §3
/ ADR 0005).

Treat `KBUILD_BUILD_TIMESTAMP` as the reproducibility signal kbuild
already uses (it's a fixed constant in a reproducible build, unset in
a normal developer build) and skip `-j` when it's set. The pahole-126+
branch sets `pahole-flags-y` with `=` (not `+=`), so split that too.

Upstream context:
  https://lore.kernel.org/lkml/20240306060818.9355-2-lukas.bulwahn@gmail.com/
  (LKML 2024-03 "kbuild: disable pahole multi-threading on reproducible
  builds")

Without this, substrate-kernels' debug-variant repro-check
(VARIANT=debug, ARCH=x86_64) fails: the BTF region of vmlinux differs
between identical builds; the `.kernel` bundles differ by ~2.9 M bytes
clustered in the `.BTF`/`.BTF_ids` payload.

Signed-off-by: substrate <substrate-kernels@agx.so>
---
diff --git a/scripts/Makefile.btf b/scripts/Makefile.btf
index b75f09f3c..a9c4f6d31 100644
--- a/scripts/Makefile.btf
+++ b/scripts/Makefile.btf
@@ -12,14 +12,19 @@ endif

 pahole-flags-$(call test-ge, $(pahole-ver), 121)	+= --btf_gen_floats

+ifndef KBUILD_BUILD_TIMESTAMP
 pahole-flags-$(call test-ge, $(pahole-ver), 122)	+= -j
+endif

 pahole-flags-$(call test-ge, $(pahole-ver), 125)	+= --skip_encoding_btf_inconsistent_proto --btf_gen_optimized

 else

 # Switch to using --btf_features for v1.26 and later.
-pahole-flags-$(call test-ge, $(pahole-ver), 126)  = -j --btf_features=encode_force,var,float,enum64,decl_tag,type_tag,optimized_func,consistent_func,decl_tag_kfuncs
+pahole-flags-$(call test-ge, $(pahole-ver), 126)  = --btf_features=encode_force,var,float,enum64,decl_tag,type_tag,optimized_func,consistent_func,decl_tag_kfuncs
+ifndef KBUILD_BUILD_TIMESTAMP
+pahole-flags-$(call test-ge, $(pahole-ver), 126) += -j
+endif

 ifneq ($(KBUILD_EXTMOD),)
 module-pahole-flags-$(call test-ge, $(pahole-ver), 126) += --btf_features=distilled_base
