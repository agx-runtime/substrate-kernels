From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: substrate <substrate-kernels@agx.so>
Date: Mon, 18 May 2026 00:00:00 +0000
Subject: [PATCH] x86/acpi: keep default_legacy_pic alive in HW_REDUCED mode

See inline comments.
(x86 ACPI VMGENID wiring).

Signed-off-by: substrate <substrate-kernels@agx.so>
---
diff --git a/arch/x86/kernel/acpi/boot.c b/arch/x86/kernel/acpi/boot.c
index a1acff778..be207cd5d 100644
--- a/arch/x86/kernel/acpi/boot.c
+++ b/arch/x86/kernel/acpi/boot.c
@@ -1409,10 +1409,24 @@ void __init acpi_generic_reduced_hw_init(void)
 	/*
 	 * Override x86_init functions and bypass legacy PIC in
 	 * hardware reduced ACPI mode.
+	 *
+	 * substrate: we ship substrate-style microVMs that use
+	 * HW_REDUCED ACPI (no PM block I/O) BUT still rely on
+	 * legacy IRQs 0..15 for virtio-mmio. Without
+	 * `default_legacy_pic` pre-allocating those IRQ descs,
+	 * `request_irq(6..12)` for the virtio devices fails
+	 * -EINVAL and nothing probes. Keep the timer/vector
+	 * overrides (those are about MS hyper-v / Apple silicon
+	 * fast-paths) but leave `legacy_pic` alone so the
+	 * pre-vector-init still allocates legacy IRQ descs.
 	 */
 	x86_init.timers.timer_init	= x86_init_noop;
-	x86_init.irqs.pre_vector_init	= x86_init_noop;
-	legacy_pic			= &null_legacy_pic;
+	/*
+	 * x86_init.irqs.pre_vector_init still calls
+	 * `init_ISA_irqs()` via the default; that's what we want
+	 * here, so don't override it either. Removing the
+	 * `legacy_pic = null_legacy_pic` line is the actual fix.
+	 */
 }
 
 static void __init acpi_reduced_hw_init(void)

