From 410719e16a44cd02afc49be432982692e721664a Mon Sep 17 00:00:00 2001
From: substrate <substrate-kernels@agx.so>
Date: Mon, 20 Jul 2026 18:24:27 -0700
Subject: [PATCH 3/3] kbuild: serialize pahole for reproducible builds

Parallel pahole assigns BTF type IDs nondeterministically. KBUILD_BUILD_TIMESTAMP is fixed for substrate-kernels reproducible builds, so omit pahole -j in that mode while retaining parallel BTF generation for ordinary builds. Based on the upstream proposal at https://lore.kernel.org/lkml/20240306060818.9355-2-lukas.bulwahn@gmail.com/.
---
 scripts/Makefile.btf | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/scripts/Makefile.btf b/scripts/Makefile.btf
index b75f09f3f..988a2a077 100644
--- a/scripts/Makefile.btf
+++ b/scripts/Makefile.btf
@@ -12,14 +12,19 @@ endif
 
 pahole-flags-$(call test-ge, $(pahole-ver), 121)	+= --btf_gen_floats
 
+ifndef KBUILD_BUILD_TIMESTAMP
 pahole-flags-$(call test-ge, $(pahole-ver), 122)	+= -j
+endif
 
 pahole-flags-$(call test-ge, $(pahole-ver), 125)	+= --skip_encoding_btf_inconsistent_proto --btf_gen_optimized
 
 else
 
 # Switch to using --btf_features for v1.26 and later.
-pahole-flags-$(call test-ge, $(pahole-ver), 126)  = -j --btf_features=encode_force,var,float,enum64,decl_tag,type_tag,optimized_func,consistent_func,decl_tag_kfuncs
+pahole-flags-$(call test-ge, $(pahole-ver), 126)  = --btf_features=encode_force,var,float,enum64,decl_tag,type_tag,optimized_func,consistent_func,decl_tag_kfuncs
+ifndef KBUILD_BUILD_TIMESTAMP
+pahole-flags-$(call test-ge, $(pahole-ver), 126) += -j
+endif
 
 ifneq ($(KBUILD_EXTMOD),)
 module-pahole-flags-$(call test-ge, $(pahole-ver), 126) += --btf_features=distilled_base
-- 
